# =============================================================================
# NexusHR Docker Deployment — Environment Variables
# =============================================================================
# Copy this file to .env before running docker-compose up.
# CRITICAL: Replace all CHANGE-ME values before deploying!

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_PASSWORD=CHANGE-ME-use-a-strong-password
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/nexushr
SPRING_DATASOURCE_USERNAME=nexushr
SPRING_DATASOURCE_PASSWORD=CHANGE-ME-use-a-strong-password

# -----------------------------------------------------------------------------
# JWT Secret
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE-ME-generate-a-secure-random-key-at-least-256-bits

# -----------------------------------------------------------------------------
# Encryption Master Key
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 16
ENCRYPTION_MASTER_KEY=CHANGE-ME-generate-a-secure-hex-key-32chars

# -----------------------------------------------------------------------------
# CORS — Allowed Frontend Origins
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:80

# -----------------------------------------------------------------------------
# Spring Profile
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# -----------------------------------------------------------------------------
# Optional: OpenAI (for future AI integration)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-key-here
