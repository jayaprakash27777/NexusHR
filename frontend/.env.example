# =============================================================================
# NexusHR Frontend — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# All variables must be prefixed with VITE_ to be exposed to the frontend.

# Backend API base URL (used by the centralized axios client)
# For production: https://your-backend-domain.com/api
VITE_API_URL=http://localhost:8080/api

# Backend base URL without /api path (used by chat, WebSocket, file URLs)
# For production: https://your-backend-domain.com
VITE_API_BASE_URL=http://localhost:8080

# WebSocket URL (Spring Boot STOMP endpoint)
# For production: https://your-backend-domain.com/api/ws
VITE_WS_URL=http://localhost:8080/api/ws

# App metadata
VITE_APP_NAME=NexusHR
VITE_APP_VERSION=1.0.0
