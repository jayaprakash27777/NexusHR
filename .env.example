# =============================================================================
# NexusHR — Root Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values for local development.
# For production, set these as environment variables in your hosting platform.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# For local dev with embedded PG, these defaults work out of the box.
# For production, point to your managed PostgreSQL instance.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/nexushr
SPRING_DATASOURCE_USERNAME=nexushr
SPRING_DATASOURCE_PASSWORD=nexushr_secret

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# CRITICAL: Change this in production! Must be at least 32 characters.
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE-ME-generate-a-secure-random-key-at-least-256-bits

# JWT token expiration (ms)
# Access token: 15 minutes = 900000
# Refresh token: 7 days = 604800000

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Master key for encrypting sensitive data (e.g., chat messages).
# CRITICAL: Change this in production! Must be exactly 32 hex characters.
# Generate with: openssl rand -hex 16
ENCRYPTION_MASTER_KEY=CHANGE-ME-generate-a-secure-hex-key-32chars

# -----------------------------------------------------------------------------
# CORS — Allowed Frontend Origins
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins.
# For production, set to your actual frontend domains.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------
# These are used during frontend build (npm run build).
VITE_API_URL=http://localhost:8080/api
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=http://localhost:8080/api/ws

# -----------------------------------------------------------------------------
# Optional: Spring Profile (for Docker deployments)
# -----------------------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=docker
